{
  "name": "pna_wasm_demo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "next": "next",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,json,css}'",
    "format:check": "prettier --check './**/*.{js,jsx,ts,tsx,json,css}'",
    "format:cargo": "cd pna_wasm/ && cargo fmt --all",
    "build:wasm": "cd pna_wasm/ && wasm-pack build --target web --release",
    "test:wasm": "cd pna_wasm/ && wasm-pack test --node --release",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "bytes": "^3.1.2",
    "next": "^16",
    "pna": "file:./pna_wasm/pkg",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bytes": "^3.1.5",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "serve": "^14",
    "typescript": "^5"
  }
}
